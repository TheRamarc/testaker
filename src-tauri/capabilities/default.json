{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "dialog:default",
    "core:path:default",
    "fs:default",
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$HOME/tnpsc_uploads" },
        { "path": "$HOME/tnpsc_uploads/**" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$HOME/tnpsc_uploads" },
        { "path": "$HOME/tnpsc_uploads/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$HOME/tnpsc_uploads" },
        { "path": "$HOME/tnpsc_uploads/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$HOME/tnpsc_uploads" },
        { "path": "$HOME/tnpsc_uploads/**" },
        { "path": "$DOWNLOADS/**" },
        { "path": "$DESKTOP/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$HOME/tnpsc_uploads" },
        { "path": "$HOME/tnpsc_uploads/**" }
      ]
    },
    {
      "identifier": "fs:allow-copy-file",
      "allow": [
        { "path": "$HOME/tnpsc_uploads" },
        { "path": "$HOME/tnpsc_uploads/**" },
        { "path": "$DOWNLOADS/**" },
        { "path": "$DESKTOP/**" }
      ]
    }
  ]
}
